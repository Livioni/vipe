{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug VIPE Infer",
            "type": "debugpy",
            "request": "launch",
            "module": "vipe.cli.main",
            "args": [
                "infer",
                "--image-dir",
                "datasets/ropedia_vipe/ep3/images/left",
                "--pipeline", "dav3_slam_only",
                "--output",
                "vipe_results/ropedia/ep3",
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}